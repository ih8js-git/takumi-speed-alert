import { ProgressIndicator, Palette, VerticalBox } from "std-widgets.slint";

export component ProcessingPage inherits VerticalBox {
    alignment: center;
    spacing: 20px;
    padding: 20px;

    in property <float> progress: 0.0;
    in property <string> processing_text: "Processing Map Data...";
    in property <string> processing_subtext: "This may take a minute. Please don't close the application.";

    Text {
        text: root.processing_text;
        font-size: 20px;
        font-weight: 700;
        horizontal-alignment: center;
        color: Palette.foreground;
    }
    
    Text {
        text: root.processing_subtext;
        font-size: 14px;
        horizontal-alignment: center;
        color: Palette.foreground;
    }

    ProgressIndicator {
        progress: root.progress;
        width: 100%;
        height: 20px;
    }
}
